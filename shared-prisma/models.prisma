model User {
  id                Int           @id @default(autoincrement())
  email             String        @unique
  name              String?
  age               Int?
  Posts             Post[]        @relation("author")
  LastModifiedPosts Post[]        @relation("lastModifiedBy")
  LikedPosts        LikedPosts[]
  M2MPosts          M2M_Post[]    @relation("M2MPostAuthor")
  MMMPosts          MMM_Post[]    @relation("MMMPostAuthor")
  M2MBugPosts       M2MBug_Post[] @relation("M2MBugPostAuthor")
}

model Post {
  id               Int           @id @default(autoincrement())
  title            String
  content          String?
  published        Boolean       @default(false)
  createdAt        DateTime      @default(now())
  author           User          @relation(fields: [authorId], references: [id], name: "author", onDelete: Cascade)
  authorId         Int
  LastModifiedBy   User          @relation(fields: [lastModifiedById], references: [id], name: "lastModifiedBy")
  lastModifiedById Int
  Images           PostsImages[]
  LikedPosts       LikedPosts[]
  metadata         Json?
}

model PostsImages {
  id     Int    @id @default(autoincrement())
  url    String
  postId Int
  Post   Post   @relation(fields: [postId], references: [id])
}

model LikedPosts {
  id       Int  @id @default(autoincrement())
  postId   Int
  Post     Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  Author   User @relation(fields: [authorId], references: [id])
  authorId Int
}

model Employee {
  id           Int        @id @default(autoincrement())
  name         String
  managerId    Int?
  manager      Employee?  @relation("ManagerSubordinates", fields: [managerId], references: [id])
  subordinates Employee[] @relation("ManagerSubordinates")
}

// Region Multi-field Id
model MFId_Category {
  id                Int                 @id
  name              String
  MFId_CategoryPost MFId_CategoryPost[]
}

model MFId_CategoryPost {
  categoryId Int
  postId     Int
  category   MFId_Category @relation(fields: [categoryId], references: [id])
  post       MFId_Post     @relation(fields: [postId], references: [id])

  @@id([categoryId, postId])
}

model MFId_Post {
  id                Int                 @id
  title             String
  MFId_CategoryPost MFId_CategoryPost[]
}

// Region M2M
model M2M_Post {
  id       Int            @id
  title    String
  authorId Int?
  author   User?          @relation("M2MPostAuthor", fields: [authorId], references: [id])
  cat1     M2M_Category[]
}

model M2M_Category {
  id     Int        @id
  name   String
  posts1 M2M_Post[]
}

// Region END M2M

// Region M2M named relation
model M2M_NC_Category {
  id     Int           @id
  name   String
  posts1 M2M_NC_Post[] @relation("M2M_NC")
}

model M2M_NC_Post {
  id    Int               @id
  title String
  cat1  M2M_NC_Category[] @relation("M2M_NC")
}

// Region END M2M named relation

// Region Multi M2M (two junctions, same target type)
model MMM_Category {
  id     Int        @id
  name   String
  posts1 MMM_Post[] @relation("M2M_NC_M1")
  posts2 MMM_Post[] @relation("M2M_NC_M2")
}

model MMM_Post {
  id       Int            @id
  title    String
  authorId Int?
  author   User?          @relation("MMMPostAuthor", fields: [authorId], references: [id])
  cat1     MMM_Category[] @relation("M2M_NC_M1")
  cat2     MMM_Category[] @relation("M2M_NC_M2")
}

// Region END Multi M2M

// Region M2M multi-junction bug models (2 junctions → different targets → keyof-union bug)
// M2MBug_Post has M2M to BOTH M2MBug_CatA and M2MBug_CatB.
// Junction tables: _M2MBug_CatAToM2MBug_Post and _M2MBug_CatBToM2MBug_Post
// keyof Relations<juncA | juncB> = intersection = {M2MBug_Post} only → AvailableM2MTargets = never
model M2MBug_Post {
  id       Int           @id
  title    String
  authorId Int?
  author   User?         @relation("M2MBugPostAuthor", fields: [authorId], references: [id])
  catsA    M2MBug_CatA[]
  catsB    M2MBug_CatB[]
}

model M2MBug_CatA {
  id    Int           @id
  name  String
  posts M2MBug_Post[]
}

model M2MBug_CatB {
  id    Int           @id
  name  String
  posts M2MBug_Post[]
}
// Region END M2M bug models
