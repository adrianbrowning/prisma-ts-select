{
  "name": "@gcm/usage-sqlite-v7",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "gen": "prisma generate",
    "test": "pnpm run test:core && pnpm run test:readme && pnpm run test:dialect",
    "lint:ts": "tsc --noEmit",
    "test:core": "node --import ../../shared-tests/client-resolver.mjs --import ../../shared-tests/test-setup.mjs --test './tests/core/**/*.spec.ts'",
    "test:readme": "node --import ../../shared-tests/client-resolver.mjs --import ../../shared-tests/test-setup.mjs --test './tests/readme/**/*.ts'",
    "test:dialect": "node --import ../../shared-tests/client-resolver.mjs --import ../../shared-tests/test-setup.mjs --test './tests/dialect/sqlite/**/*.ts' --test './tests/dialect/sqlite-v7/**/*.ts'",
    "p:r": "prisma db push --force-reset && prisma db seed",
    "lint:ts": "tsc --noEmit -p tsconfig.json",
    "lint": "lint:ts ; lint:s",
    "lint:esl": "eslint --config ../../eslint.config.ts \"{src,tests}/**/*.{j,t}s{,x}\" --cache --max-warnings=0",
    "lint:esl:fix": "pnpm lint:esl --fix",
    "lint:s": "eslint --config ../../eslint.config.style.ts \"{src,tests}/**/*.{j,t}s{,x}\" --cache --max-warnings=0",
    "lint:fix": "pnpm lint:s --fix",
    "lint:jscpd": "jscpd .",
    "lint:e18e": "pnpm dlx @e18e/cli analyze"
  },
  "imports": {
    "#dbTypes": "./generated/prisma/client.ts",
    "#client": "./src/client.ts",
    "#prisma-ts-select": "./generated/prisma-ts-select/*",
    "#dialect": "./generated/prisma-ts-select/dialects/v7.js",
    "#extend": "./generated/prisma-ts-select/extend-v7.js"
  },
  "dependencies": {
    "@gcm/prisma-ts-select": "workspace:prisma-ts-select@*"
  },
  "devDependencies": {
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "7.8.0",
    "@types/node": "^24.0.0",
    "prisma": "7.4.0",
    "typescript": "^5.9.3"
  }
}
