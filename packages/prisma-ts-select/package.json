{
  "name": "prisma-ts-select",
  "version": "0.2.0",
  "type": "module",
  "bin": {
    "prisma-ts-select": "dist/bin.cjs"
  },
  "main": "./dist/generator.cjs",
  "types": "./dist/generator.d.ts",
  "exports": {
    "./extend": {
      "types": "./dist/extend/extend.d.ts",
      "import": "./dist/extend/extend.js",
      "default": "./dist/extend/extend.js"
    },
    ".": {
      "types": "./dist/generator.d.ts",
      "require": "./dist/generator.cjs",
      "default": "./dist/generator.cjs"
    }
  },
  "scripts": {
    "pre-release": "pnpm version prerelease --preid=rc --no-git-tag-version && pnpm build && pnpm pack",
    "bp": "pnpm build && pnpm version patch && pnpm pack",
    "build": "pnpm exec rimraf dist && node build.ts",
    "reset": "rm -rf prisma/migrations/ && prisma migrate dev --name init  && prisma generate",
    "start": "node src/index.ts",
    "prisma-upgrade": "pnpm i --save-dev prisma@latest && pnpm i @prisma/client@latest",
    "lint:tsw": "pnpm tsc -w",
    "p:gen": "pnpm exec prisma generate",
    "p:dbp": "pnpm exec prisma db push",
    "p:migrate": "pnpm exec prisma migrate dev",
    "p:update": "pnpm add -D prisma@latest && pnpm add @prisma/client@latest",
    "test": "node --test tests/**/*.spec.ts",
    "2postinstall": "node src/scripts/postinstall.js",
    "doc": "pnpm exec markdown-toc -i README.md",
    "mdcode-ts": "pnpm exec mdcode",
    "readme:extract": "pnpm mdcode extract README.md",
    "readme:update": "pnpm mdcode update --transform ./transforms/readme-sql-clean.ts README.md",
    "readme:test": "pnpm --filter usage-sqlite-v7 test -- tests/readme",
    "lint:ts": "tsc --noEmit -p tsconfig.json",
    "lint": "lint:ts ; lint:s",
    "lint:esl": "eslint --config ../../eslint.config.ts \"{src,tests}/**/*.{j,t}s{,x}\" --cache",
    "lint:esl:fix": "pnpm lint:esl --fix",
    "lint:s": "eslint --config ../../eslint.config.style.ts \"{src,tests}/**/*.{j,t}s{,x}\" --cache",
    "lint:fix": "pnpm lint:s --fix",
    "lint:jscpd": "jscpd .",
    "lint:e18e": "pnpm dlx @e18e/cli analyze"
  },
  "dependencies": {
    "@prisma/generator-helper": "^6.19.3",
    "@prisma/internals": "^6.19.3",
    "ts-pattern": "^5.9.0"
  },
  "peerDependencies": {
    "@prisma/client": ">=6.0.0 <8.0.0"
  },
  "license": "MIT",
  "author": {
    "name": "Adrian Elton-Browning",
    "email": "gingacodemonkey@gmail.com"
  },
  "bugs": {
    "url": "https://github.com/adrianbrowning/prisma-ts-select/issues"
  },
  "homepage": "https://github.com/adrianbrowning/prisma-ts-select/tree/main/packages/prisma-ts-select",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adrianbrowning/prisma-ts-select.git"
  },
  "devDependencies": {
    "@prisma/client": "6.19.3",
    "@types/node": "24.13.3",
    "esbuild": "^0.28.1",
    "markdown-toc": "^1.2.0",
    "mdcode-ts": "^0.0.4",
    "prisma": "6.19.3",
    "rimraf": "^6.1.3"
  },
  "keywords": [
    "prisma",
    "generator",
    "SQL",
    "type-safe",
    "typescript"
  ],
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "target": "node",
  "release": {
    "branches": [
      "main"
    ],
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      [
        "@semantic-release/changelog",
        {
          "changelogFile": "CHANGELOG.md"
        }
      ],
      "@semantic-release/npm",
      "@semantic-release/github",
      [
        "@semantic-release/git",
        {
          "assets": [
            "CHANGELOG.md",
            "package.json"
          ],
          "message": "chore(release): set `package.json` to ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
        }
      ]
    ]
  },
  "files": [
    "./dist",
    "./assets",
    "README.md",
    "package.json"
  ],
  "publishConfig": {
    "access": "public",
    "name": "prisma-ts-select"
  }
}
