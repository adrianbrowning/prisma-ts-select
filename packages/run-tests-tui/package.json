{
  "name": "run-tests-tui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "commander": "^14.0.3",
    "ink": "^5.0.1",
    "react": "^18.2.0"
  },
  "devDependencies": {
    "@types/node": "^24.12.4",
    "@types/react": "^18.2.0"
  },
  "scripts": {
    "lint:ts": "tsc --noEmit -p tsconfig.json",
    "lint": "lint:ts ; lint:s",
    "lint:esl": "eslint --config ../../eslint.config.ts \"{src,tests}/**/*.{j,t}s{,x}\" --cache --max-warnings=0",
    "lint:esl:fix": "pnpm lint:esl --fix",
    "lint:s": "eslint --config ../../eslint.config.style.ts \"{src,tests}/**/*.{j,t}s{,x}\" --cache --max-warnings=0",
    "lint:fix": "pnpm lint:s --fix",
    "lint:jscpd": "jscpd .",
    "lint:e18e": "pnpm dlx @e18e/cli analyze"
  }
}
