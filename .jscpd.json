{
  "minTokens": 50,
  "format": [
    "typescript",
    "javascript"
  ],
  "ignore": [
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.test.js",
    "**/*.test.jsx",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "**/*.spec.js",
    "**/*.spec.jsx",
    "**/__tests__/**",
    "node_modules/**",
    "dist/**",
    "coverage/**"
  ],
  "reporters": [
    "console"
  ]
}